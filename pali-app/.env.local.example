# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Stripe (for future payment integration)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Customer Support Chatbot ──────────────────────────────────────
# OpenAI for the AI assistant (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# WhatsApp Business number for escalation handoff
# E.164 without the +, e.g. 972501234567
# If empty, the chat shows "נציג יחזור אליך בהקדם" instead of a WhatsApp button
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=

# Admin notifications on new support tickets
ADMIN_EMAIL=
ADMIN_PHONE=
